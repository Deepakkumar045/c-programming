#include <stdio.h>

void marks(int arr[], int n, int *high, int *low, float *avg)
{
    int i, sum = 0;

    *high = arr[0];
    *low = arr[0];

    for(i = 0; i < n; i++)
    {
        if(arr[i] > *high)
            *high = arr[i];

        if(arr[i] < *low)
            *low = arr[i];

        sum += arr[i];
    }

    *avg = (float)sum / n;
}

int main()
{
    int arr[] = {80, 95, 70, 88, 60};
    int high, low;
    float avg;

    marks(arr, 5, &high, &low, &avg);

    printf("Highest = %d\n", high);
    printf("Lowest = %d\n", low);
    printf("Average = %.2f", avg);

    return 0;
}
